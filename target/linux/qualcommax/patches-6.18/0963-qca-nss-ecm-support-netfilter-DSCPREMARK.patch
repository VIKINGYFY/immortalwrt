+#endif
+/* QCA NSS ECM support - End */
+
 static bool nft_payload_rebuild_vlan_hdr(const struct sk_buff *skb, int mac_off,
 					 struct vlan_ethhdr *veth)
 {
@@ -860,6 +867,11 @@ static void nft_payload_set_eval(const s
 	int offset, csum_offset, vlan_hlen = 0;
 	struct sk_buff *skb = pkt->skb;
 	__wsum fsum, tsum;
+	/* QCA NSS ECM support - Start */
+#ifdef CONFIG_NF_CONNTRACK_DSCPREMARK_EXT
+	bool dscp_hooked = false;
+#endif
+	/* QCA NSS ECM support - End */
 
 	switch (priv->base) {
 	case NFT_PAYLOAD_LL_HEADER:
@@ -919,10 +931,45 @@ static void nft_payload_set_eval(const s
 			goto err;
 	}
 
+	/* QCA NSS ECM support - Start */
+#ifdef CONFIG_NF_CONNTRACK_DSCPREMARK_EXT
+	/* Flag a network-header write targeting the DSCP byte (e.g. an nft
+	 * 'ip dscp set' statement), so the conntrack DSCP-remark extension
+	 * can be marked valid below. Deliberately fires even when the
+	 * written value equals the current one: xt_DSCP validates the
+	 * extension whenever the target runs, and an 'ip dscp set' rule
+	 * must count as a QoS rule for flows that already carry the wanted
+	 * DSCP, or idempotent firewall configs would silently lose QoS
+	 * treatment. ECN-only writes hit the same byte and are accepted as
+	 * false positives: the resulting acceleration rule remarks with the
+	 * packet's own DSCP, a no-op.
+	 */
+	if (priv->base == NFT_PAYLOAD_NETWORK_HEADER && priv->offset <= 1) {
+		switch (nft_pf(pkt)) {
+		case NFPROTO_IPV4:
+		case NFPROTO_IPV6:
+			dscp_hooked = true;
+			break;
+		}
+	}
+#endif
+	/* QCA NSS ECM support - End */
 	if (skb_ensure_writable(skb, max(offset + priv->len, 0)) ||
 	    skb_store_bits(skb, offset, src, priv->len) < 0)
 		goto err;
 
+	/* QCA NSS ECM support - Start */
+#ifdef CONFIG_NF_CONNTRACK_DSCPREMARK_EXT
+	if (dscp_hooked) {
+		enum ip_conntrack_info ctinfo;
+		struct nf_conn *ct = nf_ct_get(skb, &ctinfo);
+
+		if (ct)
+			nf_conntrack_dscpremark_ext_set_dscp_rule_valid(ct);
+	}
+#endif
+	/* QCA NSS ECM support - End */
+
 	if (priv->csum_type == NFT_PAYLOAD_CSUM_SCTP &&
 	    pkt->tprot == IPPROTO_SCTP &&
 	    skb->ip_summed != CHECKSUM_PARTIAL) {
