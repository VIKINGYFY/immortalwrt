#!/bin/sh /etc/rc.common
######################################################################
# vim: set ft=bash
# shellcheck disable=2155,3019,3043,3057,3060
######################################################################

START=94

PROG=smp_affinity

gro_state=on
checksum_state=on

log_msg() {
	local irq_name="$1" affinity="$2" irq="$3"
	msg="$(printf "Pinning IRQ($irq) %-24s to CPU ${affinity}\n" "$irq_name")"
	logger -t "$PROG" "$msg"
}

######################################################################
## Takes a comma, space separated, or range list of CPU numbers and
## returns a bitmask of CPUs.
## cpus_to_bitmask "0,1,2,3" -> f
## cpus_to_bitmask "0 1 2 3" -> f
## cpus_to_bitmask "0-3"     -> f
## cpus_to_bitmask "3"       -> 8
#######################################################################

cpus_to_bitmask() {
	local bitmask=0
	# shellcheck disable=2048
	for range in ${*//,/ }; do
		start="${range%-*}"
		end="${range#*-}"
		if [ -z "$end" ]; then
			bitmask="$((bitmask | 1 << start))"
		else
			bitmask="$((bitmask | (2 ** (end - start + 1) - 1) << start))"
		fi
	done
	printf '%x' $bitmask
}

######################################################################
## Takes a bitmask of CPUs and returns a space separated list of
## CPU numbers.
## bitmask_to_cpus f -> 0 1 2 3
######################################################################

bitmask_to_cpus() {
	[ "${1:0:2}" != "0x" ] && set -- "0x$1"
	local bitmask="$(printf '%d' "$1")"

	local cpus=""
	for i in $(seq 0 63); do
		if [ $((bitmask & 1)) -ne 0 ]; then
			cpus="$cpus $i"
		fi
		bitmask=$((bitmask >> 1))
	done
	echo "${cpus# }"
}

######################################################################
## Sets the affinity of the IRQs with the given name to the given CPU.
## 1st argument: IRQ name ("reo2host-destination-ring1") (req)
## 2nd argument: CPU number (req)
######################################################################

set_affinity() {
	local irq_name="$1" affinity="$2" affinity_file bitmask irq

	bitmask=$(cpus_to_bitmask "$affinity") || return
	awk -v irq_name="$irq_name" '
		$NF == irq_name || index($NF, irq_name "_") == 1 {
			sub(/:$/, "", $1)
			print $1
		}' /proc/interrupts | while read -r irq; do
		affinity_file="/proc/irq/$irq/smp_affinity"
		[ -w "$affinity_file" ] || continue
		if echo "$bitmask" > "$affinity_file"; then
			$enable_log && log_msg "$irq_name" "$affinity" "$irq"
		fi
	done
}

enable_affinity() {
	# Keep the hot RX and TX completion paths on separate CPUs.
	set_affinity 'edma_rxdesc' 1
	set_affinity 'edma_txcmpl' 2
}

configure_edma_offloads() {
	local dev dev_path

	command -v ethtool >/dev/null 2>&1 || return
	for dev_path in /sys/class/net/eth*; do
		[ -e "$dev_path" ] || continue
		dev="${dev_path##*/}"
		ethtool -K "$dev" gro "$gro_state" >/dev/null 2>&1
		ethtool -K "$dev" rx "$checksum_state" >/dev/null 2>&1
		ethtool -K "$dev" tx "$checksum_state" >/dev/null 2>&1
	done
}

start() {
	enable_log=true
	enable_affinity
	configure_edma_offloads
}

boot() {
	start
}
