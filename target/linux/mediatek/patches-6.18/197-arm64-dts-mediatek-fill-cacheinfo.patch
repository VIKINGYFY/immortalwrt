From: OpenWrt Builder <openwrt-devel@lists.openwrt.org>
Subject: [PATCH] arm64: dts: mediatek: fill cacheinfo

Add CPU cache hierarchy descriptions for Filogic SoCs whose CPU nodes
currently lack next-level-cache links. This avoids cacheinfo falling back
to firmware discovery on boards where firmware does not describe caches.

--- a/arch/arm64/boot/dts/mediatek/mt7981b.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7981b.dtsi
@@ -18,6 +18,7 @@
 			compatible = "arm,cortex-a53";
 			reg = <0x0>;
 			device_type = "cpu";
+			next-level-cache = <&l2_cache>;
 			enable-method = "psci";
 		};
 
@@ -25,8 +26,14 @@
 			compatible = "arm,cortex-a53";
 			reg = <0x1>;
 			device_type = "cpu";
+			next-level-cache = <&l2_cache>;
 			enable-method = "psci";
 		};
+
+		l2_cache: l2-cache {
+			compatible = "cache";
+			cache-level = <2>;
+		};
 	};
 
 	oscillator-40m {
--- a/arch/arm64/boot/dts/mediatek/mt7986a.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7986a.dtsi
@@ -23,6 +23,7 @@
 			compatible = "arm,cortex-a53";
 			reg = <0x0>;
 			device_type = "cpu";
+			next-level-cache = <&l2_cache>;
 			enable-method = "psci";
 			#cooling-cells = <2>;
 		};
@@ -31,6 +32,7 @@
 			compatible = "arm,cortex-a53";
 			reg = <0x1>;
 			device_type = "cpu";
+			next-level-cache = <&l2_cache>;
 			enable-method = "psci";
 			#cooling-cells = <2>;
 		};
@@ -39,6 +41,7 @@
 			compatible = "arm,cortex-a53";
 			reg = <0x2>;
 			device_type = "cpu";
+			next-level-cache = <&l2_cache>;
 			enable-method = "psci";
 			#cooling-cells = <2>;
 		};
@@ -47,9 +50,15 @@
 			compatible = "arm,cortex-a53";
 			reg = <0x3>;
 			device_type = "cpu";
+			next-level-cache = <&l2_cache>;
 			enable-method = "psci";
 			#cooling-cells = <2>;
 		};
+
+		l2_cache: l2-cache {
+			compatible = "cache";
+			cache-level = <2>;
+		};
 	};
 
 	clk40m: oscillator-40m {
--- a/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
@@ -49,6 +49,7 @@
 			compatible = "arm,cortex-a73";
 			reg = <0x0>;
 			device_type = "cpu";
+			next-level-cache = <&l2_cache>;
 			enable-method = "psci";
 			clocks = <&mcusys CLK_MCU_ARM_DIV_SEL>,
 				 <&topckgen CLK_TOP_XTAL>;
@@ -61,6 +62,7 @@
 			compatible = "arm,cortex-a73";
 			reg = <0x1>;
 			device_type = "cpu";
+			next-level-cache = <&l2_cache>;
 			enable-method = "psci";
 			clocks = <&mcusys CLK_MCU_ARM_DIV_SEL>,
 				 <&topckgen CLK_TOP_XTAL>;
@@ -73,6 +75,7 @@
 			compatible = "arm,cortex-a73";
 			reg = <0x2>;
 			device_type = "cpu";
+			next-level-cache = <&l2_cache>;
 			enable-method = "psci";
 			clocks = <&mcusys CLK_MCU_ARM_DIV_SEL>,
 				 <&topckgen CLK_TOP_XTAL>;
@@ -85,6 +88,7 @@
 			compatible = "arm,cortex-a73";
 			reg = <0x3>;
 			device_type = "cpu";
+			next-level-cache = <&l2_cache>;
 			enable-method = "psci";
 			clocks = <&mcusys CLK_MCU_ARM_DIV_SEL>,
 				 <&topckgen CLK_TOP_XTAL>;
@@ -93,6 +97,11 @@
 			mediatek,cci = <&cci>;
 		};
 
+		l2_cache: l2-cache {
+			compatible = "cache";
+			cache-level = <2>;
+		};
+
 		cluster0_opp: opp-table-0 {
 			compatible = "operating-points-v2";
 			opp-shared;
