### ============================================================
### NN6000 V2 满血影音创作版 - 最终配置
### 目标：NSS满血 + 大容量EMMC + 轻量长效 + 家庭媒体中心
### 内核：Linux 6.12+ (SNAPSHOT) | 包管理：APK
### ============================================================

### -----------------------------------------------------------
### 1. 基础Web界面（必须，确保能进后台）
### -----------------------------------------------------------
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y

### -----------------------------------------------------------
### 2. 平台与NSS满血加速（IPQ6000核心性能）
### -----------------------------------------------------------
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_link_nn6000=y

# WiFi驱动（AX1800级别）
CONFIG_PACKAGE_ath11k-firmware-ipq6018=y
CONFIG_PACKAGE_ipq-wifi-link_nn6000=y
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_kmod-ath11k-pci=y

# NSS硬件加速全套（千兆NAT CPU<10%的关键）
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_PACKAGE_kmod-qca-nss-crypto=y
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_nss-firmware-ipq60xx=y
CONFIG_PACKAGE_kmod-qca-nss-drv-bridge-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-vlan-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-tunipip6=y
CONFIG_PACKAGE_kmod-qca-nss-drv-gre=y

# TCP优化
CONFIG_PACKAGE_kmod-tcp-bbr=y

### -----------------------------------------------------------
### 3. EMMC与存储支持（8G空间完整利用，不伤盘）
### -----------------------------------------------------------
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-sdhci=y
CONFIG_PACKAGE_kmod-sdhci-cqhci=y
CONFIG_PACKAGE_kmod-mmc-block=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_resize2fs=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_lsblk=y

# 分区扩容插件（EMMC必备）
CONFIG_PACKAGE_luci-app-partexp=y

# 硬盘休眠（保护EMMC/USB硬盘寿命）
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-i18n-hd-idle-zh-cn=y

### -----------------------------------------------------------
### 4. 系统监控与温控（轻量，不写盘）
### -----------------------------------------------------------
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_cpufreq=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_btop=y
CONFIG_PACKAGE_zram-swap=y

# 风扇控制（改装PWM风扇必备）
CONFIG_PACKAGE_kmod-hwmon-core=y
CONFIG_PACKAGE_kmod-hwmon-gpiofan=y
CONFIG_PACKAGE_luci-app-fan=y
CONFIG_PACKAGE_luci-i18n-fan-zh-cn=y

### -----------------------------------------------------------
### 5. 科学上网双核心（电视+创作流畅翻墙）
### -----------------------------------------------------------
# PassWall2（节点负载均衡，稳定首选）
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y

# HomeProxy（sing-box内核，省内存，适合电视TUN模式）
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y

# DNS防污染与分流（Mosdns轻量高效）
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_luci-i18n-mosdns-zh-cn=y
CONFIG_PACKAGE_luci-app-smartdns=y

# 网络加速（DNS缓存+优化）
CONFIG_PACKAGE_luci-app-turboacc=y

### -----------------------------------------------------------
### 6. 家长控制与行为管理（学习规划师专属）
### -----------------------------------------------------------
# 应用过滤（OAF）- 屏蔽抖音/游戏APP
CONFIG_PACKAGE_luci-app-oaf=y
CONFIG_PACKAGE_luci-i18n-oaf-zh-cn=y

# 访问控制（IP/MAC绑定，防蹭网绕限制）
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-i18n-arpbind-zh-cn=y

# 时间控制（定时断网）
CONFIG_PACKAGE_luci-app-accesscontrol-plus=y
CONFIG_PACKAGE_luci-app-nft-timecontrol=y

# 定时任务（每周自动重启，清理缓存，极轻微写盘）
CONFIG_PACKAGE_luci-app-tasks=y
# 或备用：CONFIG_PACKAGE_luci-app-cron=y

### -----------------------------------------------------------
### 7. 文件管理与媒体中心（榨干8G，替代Docker方案）
### -----------------------------------------------------------
# iStore应用商店（图形化装插件）
CONFIG_PACKAGE_luci-app-store=y

# AList网盘聚合（挂载百度/阿里/OneDrive）
CONFIG_PACKAGE_luci-app-alist=y
CONFIG_PACKAGE_luci-i18n-alist-zh-cn=y

# 文件管理器（Web版FTP）
CONFIG_PACKAGE_luci-app-filebrowser=y
CONFIG_PACKAGE_luci-i18n-filebrowser-zh-cn=y

# Samba4文件共享（局域网高速传素材）
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y

# 磁盘管理（查看分区/挂载）
CONFIG_PACKAGE_luci-app-diskman=y

# IPTV组播转发（电视看直播，不装Docker的moonTV）
CONFIG_PACKAGE_luci-app-msd_lite=y
CONFIG_PACKAGE_luci-i18n-msd-lite-zh-cn=y

### -----------------------------------------------------------
### 8. 网络与硬件支持（5G调制解调器）
### -----------------------------------------------------------
# 5G/4G USB上网卡支持（通讯壳/移远模块）
CONFIG_PACKAGE_luci-app-modem=y
CONFIG_PACKAGE_luci-app-qmi=y
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y

# 基础网络（dnsmasq-full支持IPset分流）
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_kmod-dsa=y
CONFIG_PACKAGE_kmod-dsa-qca8k=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-dwc3-qcom=y

### -----------------------------------------------------------
### 9. 界面主题与实用工具
### -----------------------------------------------------------
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_bash=y

### -----------------------------------------------------------
### 10. 明确清理：节省空间 + 保护EMMC + 避免冲突
### -----------------------------------------------------------

# --- 移除Docker（内存/EMMC杀手，功能已由原生替代）---
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_docker-compose is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set
# CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn is not set
# CONFIG_PACKAGE_luci-lib-docker is not set

# --- 移除流量统计（EMMC写入杀手，改为实时iftop）---
# CONFIG_PACKAGE_luci-app-nlbwmon is not set
# CONFIG_PACKAGE_luci-app-wrtbwmon is not set
# CONFIG_PACKAGE_luci-app-statistics is not set
# CONFIG_PACKAGE_collectd is not set

# --- 移除冲突QoS（影响NSS硬件加速）---
# CONFIG_PACKAGE_luci-app-qos is not set
# CONFIG_PACKAGE_luci-app-nft-qos is not set
# CONFIG_PACKAGE_luci-app-sqm is not set

# --- 移除USB网卡驱动（NN6000板载网口足够，除非真需要）---
# CONFIG_PACKAGE_kmod-usb-net-rtl8152 is not set
# CONFIG_PACKAGE_kmod-usb-net-asix is not set
# CONFIG_PACKAGE_kmod-usb-net-r8152 is not set

# --- 移除视频/打印驱动（路由器不需要）---
# CONFIG_PACKAGE_kmod-video-core is not set
# CONFIG_PACKAGE_kmod-video-uvc is not set
# CONFIG_PACKAGE_kmod-usb-printer is not set
# CONFIG_PACKAGE_luci-app-p910nd is not set

# --- 移除老旧/过时软件 ---
# CONFIG_PACKAGE_dnsmasq is not set           # 已换full版
# CONFIG_PACKAGE_wpad-mini is not set         # 已换openssl版
# CONFIG_PACKAGE_wpad-basic is not set
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
# CONFIG_PACKAGE_luci-theme-bootstrap is not set
# CONFIG_PACKAGE_luci-theme-material is not set
# CONFIG_PACKAGE_luci-app-opkg is not set     # APK时代已废弃
# CONFIG_PACKAGE_luci-app-upnp is not set     # 有安全风险的自动端口映射
# CONFIG_PACKAGE_luci-app-vsftpd is not set   # FTP已过时，用Samba4/Filebrowser替代
# CONFIG_PACKAGE_luci-app-adbyby-plus is not set  # 广告过滤用Mosdns更高效
# CONFIG_PACKAGE_luci-app-wol is not set      # 按需手动安装，不预装

### -----------------------------------------------------------
### 11. 系统优化设置（编译时生效）
### -----------------------------------------------------------
CONFIG_USE_APK=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_VERSION_REPO="http://mirror.nju.edu.cn/immortalwrt/%V/targets/%S/packages"
