config general opt
  option auto_scale 'off'
  # option memory_profile 'off'
  option memory_profile 'auto'
  # option memory_profile '1gb'
  # option memory_profile '512mb'
  # option memory_profile '256mb'
  option scaling_governor 'performance'
  # ath11k per-peer statistics (station RSSI / tx rate in LuCI and iw).
  # Keeping them enabled costs a little host CPU per PPDU; set to '1' to
  # trade the station statistics away on a heavily loaded AP.
  option stats_disable '0'
