--- a/nss_hal/nss_hal.c
+++ b/nss_hal/nss_hal.c
@@ -360,10 +360,14 @@ int nss_hal_probe(struct platform_device
 	/*
 	 * Initialize the dummy netdevice.
 	 */
-	init_dummy_netdev(&nss_ctx->napi_ndev);
+	nss_ctx->napi_ndev = alloc_netdev_dummy(0);
+	if (!nss_ctx->napi_ndev) {
+		err = -ENOMEM;
+		goto err_init;
+	}
 
 	for (i = 0; i < npd->num_irq; i++) {
-		err = nss_hal_register_irq(nss_ctx, npd, &nss_ctx->napi_ndev, i);
+		err = nss_hal_register_irq(nss_ctx, npd, nss_ctx->napi_ndev, i);
 		if (err) {
 			goto err_register_irq;
 		}
@@ -857,6 +861,8 @@ err_register_irq:
 	for (i = 0; i < npd->num_irq; i++) {
 		nss_hal_clean_up_irq(&nss_ctx->int_ctx[i]);
 	}
+	free_netdev(nss_ctx->napi_ndev);
+	nss_ctx->napi_ndev = NULL;
 
 err_init:
 	if (nss_dev->dev.of_node) {
@@ -927,6 +933,11 @@ int nss_hal_remove(struct platform_devic
 		}
 	}
 
+	if (nss_ctx->napi_ndev) {
+		free_netdev(nss_ctx->napi_ndev);
+		nss_ctx->napi_ndev = NULL;
+	}
+
 	nss_info("%px: All resources freed for nss core%d", nss_ctx, nss_dev->id);
 	return 0;
 }
