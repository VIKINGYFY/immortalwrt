Makefile: do not build with -Werror

The driver is not warning-clean on GCC 15 / kernel 6.18
(-Wmissing-prototypes and friends), and kbuild dropped EXTRA_CFLAGS
support in 6.15 so errors can no longer be demoted from the packaging.

Signed-off-by: Julius Bairaktaris <julius@bairaktaris.de>

--- a/Makefile
+++ b/Makefile
@@ -602,7 +602,7 @@ ccflags-y += -I$(obj)/nss_hal/include -I
 
 ccflags-y += -I$(obj)/nss_data_plane/hal/include
 ccflags-y += -DNSS_PM_DEBUG_LEVEL=0 -DNSS_SKB_REUSE_SUPPORT=1
-ccflags-y += -Wall -Werror
+ccflags-y += -Wall
 
 KERNELVERSION := $(word 1, $(subst ., ,$(KERNELVERSION))).$(word 2, $(subst ., ,$(KERNELVERSION)))
 
