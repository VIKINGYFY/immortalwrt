mirror: fix build with kernel 6.18

- Sysctl tables lost the .child member in kernel 6.5 and
  register_sysctl_table() is gone; register the leaf table via
  register_sysctl("dev/nss/mirror", ...) and drop the three hand-rolled
  directory tables.
- Since kernel 5.8 sysctl proc handlers receive a kernel-space buffer,
  so the copy_from_user() on it fails at runtime; take the buffer as
  plain kernel memory and memcpy it.
- Drop -Werror from the module ccflags: the vendor code is not
  warning-clean on GCC 15 / kernel 6.18, and kbuild dropped
  EXTRA_CFLAGS support in 6.15 so the packaging can no longer demote
  errors from outside.

- Reject the legacy (pre-wifili) wifi-vdev nexthop case instead of
  calling into the ipq806x-only wifi subsystem: nss_wifi_get_context()
  is not built on this target, so the reference cannot link.

Signed-off-by: Julius Bairaktaris <julius@bairaktaris.de>

--- a/mirror/Makefile
+++ b/mirror/Makefile
@@ -2,7 +2,7 @@
 
 ccflags-y += $(NSS_CCFLAGS) -I$(obj)/../exports
 ccflags-y += -DNSS_MIRROR_DEBUG_LEVEL=2
-ccflags-y += -Wall -Werror
+ccflags-y += -Wall
 
 obj-m += qca-nss-mirror.o
 qca-nss-mirror-objs := \
--- a/mirror/nss_mirror_ctl.c
+++ b/mirror/nss_mirror_ctl.c
@@ -480,7 +480,12 @@ static int nss_mirror_ctl_parse_enable_i
 	type = nss_dynamic_interface_get_type(nss_ctx, if_num);
 
 	if (type == NSS_DYNAMIC_INTERFACE_TYPE_VAP) {
-		status = nss_wifi_vdev_set_next_hop(nss_wifi_get_context(), if_num, mirror_if_num);
+		/*
+		 * Legacy (pre-wifili) wifi vdevs only exist on ipq806x-class
+		 * firmware; the wifi subsystem backing them is not built here.
+		 */
+		nss_mirror_warn("Legacy wifi vdev nexthop not supported. if_num: %u\n", if_num);
+		return -1;
 	} else if (if_num < NSS_MAX_PHYSICAL_INTERFACES) {
 		status = nss_phys_if_set_nexthop(nss_ctx, if_num, mirror_if_num);
 	} else {
@@ -755,7 +760,7 @@ static int32_t nss_mirror_ctl_parse_cmd(
  *	Mirror sysctl config handler.
  */
 static int nss_mirror_ctl_config_handler(compat_const struct ctl_table *ctl, int write,
-		 void __user *buf, size_t *lenp, loff_t *ppos)
+		 void *buf, size_t *lenp, loff_t *ppos)
 {
 	char *buffer, *pfree;
 	char * nextarg;
@@ -778,10 +783,7 @@ static int nss_mirror_ctl_config_handler
 
 	pfree = buffer;
 
-	if (copy_from_user(buffer, buf, count)) {
-		vfree(pfree);
-		return -EFAULT;
-	}
+	memcpy(buffer, buf, count);
 
 	nextarg = nss_mirror_ctl_read_nextarg(&buffer);
 	if (!nextarg) {
@@ -918,48 +920,12 @@ static struct ctl_table nss_mirror_table
 };
 
 /*
- * nss mirror dir
- */
-static struct ctl_table nss_mirror_root_dir[] = {
-	{
-		.procname		= "mirror",
-		.mode			= 0555,
-		.child			= nss_mirror_table,
-	},
-	{ }
-};
-
-/*
- * nss mirror sysctl nss root dir
- */
-static struct ctl_table nss_mirror_nss_root_dir[] = {
-	{
-		.procname		= "nss",
-		.mode			= 0555,
-		.child			= nss_mirror_root_dir,
-	},
-	{ }
-};
-
-/*
- * nss mirror sysctl root dir
- */
-static struct ctl_table nss_mirror_root[] = {
-	{
-		.procname		= "dev",
-		.mode			= 0555,
-		.child			= nss_mirror_nss_root_dir,
-	},
-	{ }
-};
-
-/*
  * nss_mirror_ctl_register()
  *	Register command line interface for mirror.
  */
 int nss_mirror_ctl_register(void)
 {
-	nss_mirror_ctl_header = register_sysctl_table(nss_mirror_root);
+	nss_mirror_ctl_header = register_sysctl("dev/nss/mirror", nss_mirror_table);
 	if (!nss_mirror_ctl_header) {
 		nss_mirror_warn("Creating sysctl directory table header for mirror failed\n");
 		return -1;
