Use the current timer API

Kernel 6.15 removed the del_timer_sync()/try_to_del_timer_sync()
wrappers (now timer_delete_sync()/timer_delete_sync_try()) and 6.18
removed from_timer() (now timer_container_of()).

Signed-off-by: Julius Bairaktaris <julius@bairaktaris.de>

--- a/mc_netlink.c
+++ b/mc_netlink.c
@@ -717,7 +717,7 @@ static void __mc_netlink_receive(struct
 					mc->local_query_interval = i->val * HZ;
 					if (timer_pending(&mc->qtimer) ?
 						time_after(mc->qtimer.expires, jiffies + mc->local_query_interval) :
-							try_to_del_timer_sync(&mc->qtimer) >= 0) {
+							timer_delete_sync_try(&mc->qtimer) >= 0) {
 						if (mc->started)
 							mod_timer(&mc->qtimer, jiffies + mc->local_query_interval);
 					}
