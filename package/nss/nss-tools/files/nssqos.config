# NSS QoS marking - DSCP marking and fast-lane prioritization for the
# NSS-accelerated SQM (see Status -> NSS Offload and the wiki's SQM page).
#
# Each enabled rule marks BOTH directions of matching connections: once as
# written and once with source/destination mirrored. Marking survives NSS
# acceleration: the firmware rewrites the DSCP field and steers the flow
# into the SQM fast lane on offloaded packets too.
#
# What a DSCP class buys you on this router (three separate effects):
#   1. WAN fast lane - classes cs4/cs5/cs6/cs7/ef/va take a strict-priority
#      lane ahead of the SQM queue in both directions (that is the ONLY
#      WAN-queue effect of the value; the shaper itself is single-tin).
#   2. Wi-Fi WMM - mac80211 maps DSCP to a Wi-Fi access category:
#      ef/cs6/cs7 -> Voice, cs4/cs5/af4x/cs3/af3x -> Video, cs1 -> Background.
#      So marking helps the air even though the WAN shaper is single-tin.
#   3. Wire mark - what leaves toward the ISP / downstream devices. ISPs
#      routinely bleach this, so egress marks are effectively local-only;
#      the fast lane rides an internal priority mark, not the wire DSCP.
#
# Classes follow RFC 4594 service classes: one class per traffic role, no
# contradictions (all interactive gaming is cs4, all voice is ef, etc.).
#
# Rule options:
#   name       - free-form label
#   enabled    - '1' to activate, '0' to keep as an inert example
#   proto      - 'udp', 'tcp' or 'tcpudp'
#   src_ip     - source host(s)/CIDR(s), space-separated, IPv4 and/or
#                IPv6 (optional; mixed lists render one rule per family)
#   dest_ip    - destination host(s)/CIDR(s), same syntax (optional)
#   src_port   - source port(s): '443', '27015-27030', '80 443' (optional)
#   dest_port  - destination port(s), same syntax (optional)
#   domain     - destination DNS name(s), one per 'list domain' line
#                (optional). The router resolves them itself and keeps a
#                per-rule address set fresh (re-resolved every
#                resolve_interval seconds), so this works no matter which
#                DNS server the clients use. Covers CDNs whose per-stream
#                subdomains resolve to the zone's shared front-end
#                addresses: one apex name matches every edge host.
#                Combines with dest_ip (either matches) and src_ip
#                (must also match).
#   class      - DSCP class: cs0-cs7, af11-af43, ef, va, le
#   fastlane   - 'auto' (default: on for cs4/cs5/cs6/cs7/ef/va), '1' or '0'.
#                Fast-laned flows bypass the SQM queue in both directions;
#                mark sparse traffic only (games, calls, DNS) - a bulk
#                download in the fast lane starves everything else.

# Global options:
#   enabled      - master switch
#   wash_ingress - '1': reset untrusted inbound DSCP to CS0 (marking rules
#                  below still re-mark what they match). Left off: the
#                  download re-marks are what drive Wi-Fi WMM on this stack.
#   wash_egress  - '1': send everything to the ISP as CS0; fast-lane
#                  steering survives (it rides the priority mark)
#   wan_device   - override the WAN L3 device for the wash rules. The
#                  auto-detection assumes the conventional logical interface
#                  name 'wan' (pppoe-wan on PPPoE, else network.wan.device);
#                  set this if your WAN interface is named differently.
#   resolve_interval - seconds between re-resolves of 'domain' rules
#                  (default 300)

config global 'global'
	option enabled '1'
	option wash_ingress '0'
	option wash_egress '0'

# --- Active by default: sparse, latency-critical, low false-positive -------

# DNS - tiny, sparse and latency-critical: a textbook fast-lane candidate.
# Matches any resolver (ISP, public, or a local forwarder the firewall
# DNATs to); the mirrored reply direction is covered automatically, and
# port 853 also catches DoT.
config rule
	option name 'DNS'
	option enabled '1'
	option proto 'tcpudp'
	option dest_port '53 853'
	option class 'cs5'

# Real-Time Interactive (RFC 4594 CS4) - the single class for ALL interactive
# gaming, consoles and PC alike. Xbox / CoD game-state on UDP 3074 (older CoD
# titles use up to 3079), CoD-PC via Battle.net on 20500/20510/28960 plus the
# classic Blizzard range 6112-6119; CoD on Steam rides the Steam rule below.
# NOT matched on purpose: shared STUN 3478-3480 (Teams/Zoom/WebRTC media
# would land in the fast lane), the Xbox IPsec/Teredo transports 500/4500/
# 3544 (real VPN tunnels ride the same ports), and PSN's dynamic
# 49152-65535 game range.
config rule
	option name 'Game consoles / Call of Duty'
	option enabled '1'
	option proto 'udp'
	option dest_port '3074-3079 6112-6119 20500 20510 28960'
	option class 'cs4'

# Valve's game-traffic + voice envelope (game traffic / SDR relays UDP
# 27000-27250; Steamworks P2P/voice 4379-4380). UDP only: bulk Steam
# DOWNLOADS ride HTTP/TCP and must never enter the fast lane.
config rule
	option name 'PC games - Steam/Source/CS2'
	option enabled '1'
	option proto 'udp'
	option dest_port '27000-27250 4379 4380'
	option class 'cs4'

# Riot game-state (League 5000-5500 + 7000-8000, Valorant 7000-8000 +
# 8180-8181). The client/chat/patcher (TCP 2099/5222-5223/8088) and the
# in-game voice ports (dynamic 50-port window anywhere in 1024-65000) are
# deliberately not matched - only the UDP game stream belongs in the lane.
config rule
	option name 'PC games - Riot (League/Valorant)'
	option enabled '1'
	option proto 'udp'
	option dest_port '5000-5500 7000-8000 8180-8181'
	option class 'cs4'

# MS Teams media rides UDP 3478-3481 to Microsoft's Teams relays (the
# 'Optimize' row, ID 11, of the M365 endpoint list). Scoping to the relay
# CIDRs disambiguates 3478 from console/game STUN. The 50000-50059 client
# port ranges are NOT matched: they only exist when a tenant admin pins
# them - the client default is random source ports.
config rule
	option name 'Video call - MS Teams'
	option enabled '1'
	option proto 'udp'
	option dest_ip '52.112.0.0/14 52.122.0.0/15 2603:1063::/38'
	option dest_port '3478-3481'
	option class 'af41'

# Discord voice/video. Destination UDP ports per Discord staff: 50000-50032
# and 19294-19344, both inclusive. Not guaranteed static - if voice stops
# matching, re-check Discord's current ranges.
config rule
	option name 'Video call - Discord voice'
	option enabled '1'
	option proto 'udp'
	option dest_port '50000-50032 19294-19344'
	option class 'af41'

# WhatsApp voice/video calls. Ports per WhatsApp's own "Can't make voice/video
# calls" help articles: UDP/TCP 3478, 3480 and 3484 (the voice article also
# lists 443 as a fallback). 443 is deliberately NOT matched - it is all of
# HTTPS and would sweep the entire web into this class. 3478/3480 are shared
# WebRTC/STUN (also Teams/Zoom/console media); the games rule above refuses
# them, but it refuses them from the CS4 *fast lane*, where shared STUN would
# starve the link. Here the class is AF41 - managed queue + Wi-Fi Video, never
# fast-laned - so other real-time media incidentally landing here is harmless:
# AF41 is already what the Teams/Zoom/Discord call rules assign.
config rule
	option name 'Video call - WhatsApp'
	option enabled '1'
	option proto 'tcpudp'
	option dest_port '3478 3480 3484'
	option class 'af41'

# --- Examples (enabled '0'): flip on and tune to your setup ----------------

# Telephony signaling (RFC 4594 CS5). Safe - narrow, sparse. 5060/5061
# cover SIP and SIP-over-TLS (Telekom consumer lines signal on UDP 5060,
# DeutschlandLAN SIP-Trunk is TCP-only); 5070/5080 catch the Telekom
# platform's inbound SIP toward the PBX/client. Telekom's own CPE preset
# marks SIP CS6 - both CS5 and CS6 ride this router's fast lane.
config rule
	option name 'VoIP - SIP signaling'
	option enabled '0'
	option proto 'tcpudp'
	option dest_port '5060 5061 5070 5080'
	option class 'cs5'

# Voice bearer (RFC 4594 EF - also Telekom's own preset for RTP). The
# ranges below are Telekom's published RTP ports for consumer lines
# (UDP 30000-31000 + 40000-41000); DeutschlandLAN SIP-Trunk uses the
# platform-side range 9000-27000 instead. Other providers: scope to their
# documented RTP range or your phone's IP - a bulk UDP flow landing in a
# too-broad range sits in the EF fast lane and starves everything. Do not
# scope by provider IP: Telekom explicitly documents their platform
# clusters as too dynamic to pin.
config rule
	option name 'VoIP - RTP media'
	option enabled '0'
	option proto 'udp'
	option dest_port '30000-31000 40000-41000'
	option class 'ef'

# Multimedia conferencing (RFC 4594 AF41). NOT fast-laned on purpose: a video
# call is a few Mbit/s, not sparse - it belongs in the managed queue, and af41
# still gets Wi-Fi Video. Zoom meeting media is UDP 8801-8810 (Zoom-exclusive
# ports); its 3478/3479 TURN fallback is shared STUN and not matched.
config rule
	option name 'Video call - Zoom'
	option enabled '0'
	option proto 'udp'
	option dest_port '8801-8810'
	option class 'af41'

# Broadcast video (RFC 4594 CS3). Telekom MagentaTV rides the same PPPoE/VID7
# uplink; its live channels are multicast (PPE-bridged). Scope to the set-top
# box IP or the multicast group if you use IPTV.
config rule
	option name 'IPTV - Telekom MagentaTV'
	option enabled '0'
	option proto 'udp'
	option class 'cs3'

# Scavenger (RFC 4594 CS1). Example matches the classic BitTorrent port range;
# to deprioritize a NAS/backup host instead, drop dest_port and set src_ip to
# that host. Never fast-laned. On this single-tin WAN SQM cs1 mainly buys Wi-Fi
# Background (AC_BK) and downstream honoring; switch the SQM to cake diffserv4
# for a true WAN bulk tin.
config rule
	option name 'Bulk / backups / torrents'
	option enabled '0'
	option proto 'tcpudp'
	option dest_port '6881-6889'
	option class 'cs1'

# Multimedia streaming (RFC 4594 AF31) from a KNOWN service - a personal
# media server or a specific CDN - matched by name instead of by port.
# 'domain' follows the service's address changes automatically, and one
# apex name covers every per-stream edge subdomain when the CDN fronts
# them with shared zone addresses (the usual anycast setup). af31 buys
# Wi-Fi Video and downstream honoring; deliberately NO fast lane - a
# buffer burst at line rate in the fast lane would starve interactive
# traffic.
config rule
	option name 'Video stream - my media CDN'
	option enabled '0'
	option proto 'tcpudp'
	option dest_port '443'
	option class 'af31'
	list domain 'cdn.example.com'

# Big-name streaming (Netflix / YouTube / Spotify / Twitch) has no rule on
# purpose. By port it is indistinguishable from web (all HTTPS/QUIC on
# 443), and 'domain' cannot pin it either: these CDNs hand each player
# its own per-session edge hostnames (e.g. rN---sn-xxxx.googlevideo.com)
# whose addresses are NOT shared with any resolvable parent - resolving
# 'googlevideo.com' or 'youtube.com' catches the website, not the video
# bytes. 'domain' works where the probe shows shared front-end addresses:
#   nslookup <edge host seen in traffic>  vs  nslookup <apex>
# same addresses (typical for Cloudflare/anycast-fronted zones) -> one
# apex entry covers every edge host; different addresses (Google, Netflix
# OCA, Akamai-style per-edge CDNs) -> leave it alone. Best practice for
# big streaming is CS0 and fq_codel - never fast-lane buffered video.
