#!/bin/sh
# Emit the conntrack table as JSON for the LuCI "NSS Connections" viewer.
# Works for NSS-accelerated flows too: ECM periodically syncs their packet
# and byte counters back into conntrack, so rate deltas computed from two
# samples reflect offloaded traffic. The DSCP class of connections marked
# by nssqos rides in the ct mark (dscp | 0x80, qosmate-compatible).

exec awk '
BEGIN { printf "[" ; first = 1 }
/^ipv[46]/ {
	fam = $1; proto = $3; timeout = $5
	state = ""
	# tuples/counters appear twice: first = original, second = reply.
	# awk arrays persist across records - clear them or absent fields
	# (e.g. counters with acct off) would leak stale values.
	delete src; delete dst; delete sport; delete dport
	delete pkts; delete bytes
	pkts[1] = 0; pkts[2] = 0; bytes[1] = 0; bytes[2] = 0
	ns = 0; np = 0; nb = 0; nsp = 0; ndp = 0; nd = 0
	mark = 0
	for (i = 6; i <= NF; i++) {
		if (index($i, "=") == 0) {
			if (state == "" && $i !~ /^\[/) state = $i
			continue
		}
		split($i, kv, "=")
		k = kv[1]; v = kv[2]
		if (k == "src") src[++ns] = v
		else if (k == "dst") dst[++nd] = v
		else if (k == "sport") sport[++nsp] = v
		else if (k == "dport") dport[++ndp] = v
		else if (k == "packets") pkts[++np] = v
		else if (k == "bytes") bytes[++nb] = v
		else if (k == "mark") mark = v
	}
	# require the full original tuple; counters may be absent without acct
	if (ns < 1 || nsp < 1) next
	if (!first) printf ","
	first = 0
	printf "{\"family\":\"%s\",\"proto\":\"%s\",\"state\":\"%s\",\"timeout\":%d,", fam, proto, state, timeout
	printf "\"src\":\"%s\",\"sport\":%d,\"dst\":\"%s\",\"dport\":%d,", src[1], sport[1], dst[1], dport[1]
	printf "\"orig_pkts\":%d,\"orig_bytes\":%d,\"repl_pkts\":%d,\"repl_bytes\":%d,", pkts[1], bytes[1], pkts[2], bytes[2]
	printf "\"mark\":%d}", mark
}
END { printf "]\n" }
' /proc/net/nf_conntrack 2>/dev/null
